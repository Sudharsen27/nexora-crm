# =============================================================================
# LOCAL DEVELOPMENT — copy this file to .env and fill in your values
# =============================================================================

DATABASE_URL=postgresql://nexora:nexora@localhost:5432/nexora
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
SECRET_KEY=dev-secret-change-in-production
CORS_ORIGINS=["http://localhost:3000"]
DEBUG=true
FRONTEND_URL=http://localhost:3000
RUN_MIGRATIONS_ON_STARTUP=true
PASSWORD_RESET_EXPIRE_MINUTES=60

# Public backend URL (for email open/click tracking)
BACKEND_PUBLIC_URL=http://localhost:8000

# Email — local: Gmail SMTP works. Production (Render free): use Resend API (SMTP ports blocked).
# Resend: https://resend.com — free 3,000 emails/month
# RESEND_API_KEY=re_xxxxxxxx
# SMTP_FROM_EMAIL=onboarding@resend.dev
# SMTP_FROM_NAME=Nexora
#
# Local SMTP (when RESEND_API_KEY is empty):
# Create App Password: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM_EMAIL=your@gmail.com
SMTP_FROM_NAME=Nexora
SMTP_USE_TLS=true

# Document storage — db (default) stores bytes in PostgreSQL; supabase uses Supabase Storage
DOCUMENT_STORAGE_BACKEND=db
DOCUMENT_MAX_FILE_BYTES=52428800
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key
# SUPABASE_STORAGE_BUCKET=documents

# AI Assistant (OpenAI-compatible). Get a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...
# AI_MODEL=gpt-4o-mini
# AI_BASE_URL=https://api.openai.com/v1
# For Azure/OpenRouter/local Ollama, set AI_BASE_URL to the compatible endpoint.

# =============================================================================
# PRODUCTION (Render backend) — set these in Render → Environment, NOT in .env
# =============================================================================
#
# DATABASE_URL=<from Supabase>
# SECRET_KEY=<long random string>
# DEBUG=false
# FRONTEND_URL=https://your-app.vercel.app
# CORS_ORIGINS=["https://your-app.vercel.app"]
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
# COOKIE_SECURE=true
# COOKIE_SAMESITE=none
# RUN_MIGRATIONS_ON_STARTUP=true
# BACKEND_PUBLIC_URL=https://your-api.onrender.com
#
# Production email (Resend — required on Render free tier):
# RESEND_API_KEY=re_xxxxxxxx
# SMTP_FROM_EMAIL=onboarding@resend.dev
# SMTP_FROM_NAME=Nexora
#
# Do NOT use Gmail SMTP on Render free tier (ports 587/465 blocked).
# =============================================================================
# PRODUCTION (Vercel frontend) — set in Vercel → Environment Variables
# =============================================================================
#
# NEXT_PUBLIC_API_URL=https://your-api.onrender.com/api/v1
